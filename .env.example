# TrafficVision-AI Environment Configuration
# Copy this file to .env and update values as needed.

# Flask secret key (required for session security)
SECRET_KEY=change-me-to-a-random-secret

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/

# SQLAlchemy database URI
DATABASE_URL=sqlite:///instance/traffic_violations.db

# Path to custom helmet detection YOLO model
HELMET_MODEL_PATH=models/helmet_model.pt

# Temporal verification parameters
TEMPORAL_DECAY=0.85
TEMPORAL_THRESHOLD=1.5
TEMPORAL_MAX_WINDOW=10

# Server port (also used by start.js for frontend proxy)
PORT=5050

# Frontend API base URL (set automatically by start.js)
VITE_API_BASE_URL=http://localhost:5050